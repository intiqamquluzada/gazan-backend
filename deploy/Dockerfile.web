# ─────────────────────────────────────────────────────────────
# Nginx serving the pre-built Flutter web bundle.
# We don't build Flutter in Docker — too heavy. The build is done
# on the dev machine before the artifact is shipped.
# ─────────────────────────────────────────────────────────────
FROM nginx:alpine

# Static bundle copied into image
COPY web /usr/share/nginx/html

# Reverse proxy + SPA fallback
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80
